# See docs/environment.md for what each of these does and one-time setup
# steps (OAuth apps, PIN flows, generating secrets, etc). Every integration
# here is optional and degrades gracefully except ORIGIN.

# ── Core ──────────────────────────────────────────────────────────────────

# Required in production — never set in a committed .env.
ORIGIN=https://razerghost.xyz

# Signs the session cookie (HMAC) — not a GitHub value
SESSION_SECRET=

# Raise for large Spotify export uploads (adapter-node default is 512kb)
BODY_SIZE_LIMIT=200M

# ── GitHub login gate (/notes, /admin, /spotify-import, /newtab) ──────────

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Spotify "now playing" + listening history ─────────────────────────────

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Listens page (/listens) storage
SPOTIFY_HISTORY_DB_PATH=

# Live scrobbling between Spotify exports
SPOTIFY_SCROBBLE_SECRET=

# ── Simkl (watching/watchlist) ─────────────────────────────────────────────

SIMKL_CLIENT_ID=
SIMKL_ACCESS_TOKEN=

# Simkl detail cache (non-destructive if lost)
SIMKL_CACHE_DB_PATH=

# ── /notes ──────────────────────────────────────────────────────────────────

NOTES_DB_PATH=
NOTES_ATTACHMENTS_DIR=

# ── Media library (devlog/project cover, gallery, and body images) ────────

MEDIA_DIR=

# ── Homepage "Right now" card, edited at /admin/status ────────────────────

STATUS_DB_PATH=

# ── /newtab background photo, configurable at /newtab itself ─────────────

UNSPLASH_ACCESS_KEY=
NEWTAB_SETTINGS_DB_PATH=

# ── Git-based backup of data/ to a private repo — see docs/backups.md ────

BACKUP_SECRET=
BACKUP_GIT_REMOTE=
BACKUP_GIT_BRANCH=main
BACKUP_GIT_USER_NAME=ghostbase-backup
BACKUP_GIT_USER_EMAIL=backup@localhost
