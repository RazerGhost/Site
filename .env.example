# adapter-node requires ORIGIN to be set to the site's public URL in
# production — it's used to build absolute URLs and to validate incoming
# request origins. Without it, adapter-node falls back to guessing from
# request headers, which can misbehave behind a reverse proxy (Coolify's
# Traefik). Set this in Coolify's environment variables UI, not in a
# committed .env file.
ORIGIN=https://razerghost.xyz

# Spotify "now playing" widget (src/lib/components/SpotifyWidget.svelte).
# Optional — the widget shows "Spotify not connected" if these are unset.
#
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET come from that app
# 3. SPOTIFY_REFRESH_TOKEN requires a one-time OAuth authorization code flow
#    with the `user-read-currently-playing user-read-recently-played` scopes
#    (space-separated in the authorize URL's `scope` param), exchanged for a
#    refresh token (this is a manual step done once, not part of the app
#    itself). The recently-played history section of the widget silently
#    hides itself if the token only has `user-read-currently-playing`.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
